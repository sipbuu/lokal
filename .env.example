# Lokal (via electron) stores its DB at:
#   Windows: C:\Users\<you>\AppData\Roaming\lokal-music\data
#   macOS:   ~/Library/Application Support/lokal-music/data
#   Linux:   ~/.config/lokal-music/data
#
# Leave blank to use ./data/ in the project folder (separate from Electron).

LOKAL_DATA_DIR=

# Web server port (default 3421)
PORT=3421
