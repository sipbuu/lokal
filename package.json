{
  "name": "lokal-music",
  "version": "1.6.1",
  "description": "Local-first music player built w/ Electron and React. Designed for people with large local music libraries who'd like a modern listening experience w/o the burdens of streaming subscriptions.",
  "author": "sipbuu <97703296+sipbuu@users.noreply.github.com>",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:web": "concurrently \"vite\" \"node server/start.js\"",
    "build": "vite build && electron-builder",
    "server": "node server/start.js",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "rebuild:electron": "electron-rebuild",
    "rebuild:web": "npm rebuild better-sqlite3",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.lokal.music",
    "productName": "Lokal",
    "icon": "public/lokal-icon.ico",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "server/**/*"
    ],
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "sipbuu",
      "repo": "lokal"
    },
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "public/lokal-icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "public/lokal-icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category-music"
    },
    "linux": {
      "icon": "public/lokal-icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Music",
      "maintainer": "sipbuu <97703296+sipbuu@users.noreply.github.com>"
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "discord-rpc": "^4.0.1",
    "dotenv": "^16.4.5",
    "electron-log": "^5.4.3",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "express": "^4.18.3",
    "fs-extra": "^11.3.3",
    "multer": "^1.4.5-lts.1",
    "music-metadata": "^7.14.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "framer-motion": "^11.0.8",
    "lucide-react": "^0.344.0",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0",
    "zustand": "^4.5.2"
  }
}
